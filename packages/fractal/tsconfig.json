{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": "./",
    "target": "esnext",
    "useDefineForClassFields": true
  },
  "include": [
    "./*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "./.storybook/*.ts",
    "./.storybook/*.tsx",
    "./.storybook/*.mdx",
    "./stories"
  ],
  "files": ["global.d.ts"],
  "references": []
}
