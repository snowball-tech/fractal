{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "lib": ["DOM", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": "./src",
    "target": "esnext",
    "useDefineForClassFields": true
  },
  "include": ["src/**/*.ts"],
  "files": [],
  "references": []
}
